{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "skipLibCheck": true,
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"],
      "@clicker/atproto-idb": ["../../packages/atproto-idb/src/index.ts"]
    }
  },
  "include": [
    ".svelte-kit/ambient.d.ts",
    ".svelte-kit/non-ambient.d.ts",
    ".svelte-kit/types/**/$types.d.ts",
    "src/**/*"
  ],
  "exclude": [
    "node_modules/**",
    "src/**/*.test.ts",
    "src/test-setup.ts",
    "src/__mocks__/**",
    "src/tests/**"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
