{
  "name": "clicker",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/clicker/src",
  "targets": {
    "build": {
      "command": "npm run build",
      "options": {
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/build"],
      "dependsOn": ["^build"]
    },
    "validate": {
      "command": "npm run validate",
      "options": {
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "command": "npm run dev",
      "options": {
        "cwd": "{projectRoot}"
      }
    }
  }
}
